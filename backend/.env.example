PORT=4000
NODE_ENV=production

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-at-least-64-chars

# Admin credentials (hashed at startup if ADMIN_PASSWORD_HASH not set)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# PostgreSQL (panel's own DB for storing app metadata)
DATABASE_URL=postgresql://paneluser:panelpass@localhost:5432/panel

# Paths
APPS_DIR=/var/www/apps
NGINX_AVAILABLE=/etc/nginx/sites-available
NGINX_ENABLED=/etc/nginx/sites-enabled
SCRIPTS_DIR=/opt/panel/scripts

# Panel port range for hosted apps
APP_PORT_START=3001
APP_PORT_END=3999
